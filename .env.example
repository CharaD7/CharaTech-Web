# Supabase
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

SUPABASE_PROJECT_URL="https://[YOUR_SUPABASE_PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR_SUPABASE_ANON_KEY]"
SUPABASE_JWT_SECRET="[YOUR_SUPABASE_JWT_SECRET]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR_SUPABASE_SERVICE_ROLE_KEY]"

# Firebase Configuration
FIREBASE_API_KEY=AIza_your_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123
FIREBASE_ADMIN_CREDENTIALS_JSON='YOUR_FIREBASE_ADMIN_SDK_JSON_HERE'

# Admin Configuration
ADMIN_EMAIL=admin@charatech.com
ADMIN_SUPABASE_UID=your_supabase_uid_here
ADMIN_FIREBASE_UID=your_firebase_uid_here

# Dialogflow Configuration (JSON must use single quotes outside, double inside)
DIALOGFLOW_PROJECT_ID=your-dialogflow-project
DIALOGFLOW_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
DIALOGFLOW_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----","client_email":"your-service-account@project.iam.gserviceaccount.com"}'

# App Configuration
NUXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Secret (CHANGE THIS TO A SECURE RANDOM STRING)
JWT_SECRET=your-secure-random-jwt-secret-minimum-32-characters-long

# GitHub Integration (for Project Timeline feature)
# Create a Personal Access Token at https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_OWNER=CharaD7
# Set this to a secure random string, then add same value as Webhook Secret in your GitHub repo settings
GITHUB_WEBHOOK_SECRET=your-random-webhook-secret-here

# Linear Integration (for Issue Tracking)
# Get your API key from https://linear.app/settings/api
LINEAR_API_KEY=lin_your_api_key_here

# Calendly Integration (for Booking System)
# Get access token from https://calendly.com/integrations/api_webhooks
CALENDLY_ACCESS_TOKEN=your_calendly_access_token
# Get client ID and secret from https://calendly.com/integrations/api_webhooks
CALENDLY_CLIENT_ID=your_calendly_client_id
CALENDLY_CLIENT_SECRET=your_calendly_client_secret
# Webhook signing key from Calendly webhook configuration
CALENDLY_WEBHOOK_SIGNING_KEY=your_calendly_webhook_signing_key

# OpenAI (already configured - for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
